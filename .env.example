# OpenAudit - Environment Configuration
# Copy this file to .env and fill in your values

# Razorpay Payment Gateway
# Get these from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx

# Razorpay Webhook Secret (optional - for payment status updates)
# Set this up at https://dashboard.razorpay.com/app/webhooks
RAZORPAY_WEBHOOK_SECRET=

# Dashboard server port (default: 3456)
PORT=3456

# Dashboard Express server URL (optional)
# If your dashboard is running at a public URL, webhook events from Vercel
# will be forwarded here for DB persistence.
# Example: https://dashboard.example.com
DASHBOARD_URL=
